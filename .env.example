# =============================================================================
# RUTAS — copiar este archivo como .env y completar los valores
# =============================================================================

# Carpeta compartida: el anfitrión lee de aquí los CSVs descargados por la VM
# En la VM la carpeta se publica como \\VBOXSVR\vpncompartido
CSV_LOCAL_FOLDER=C:\Users\TU_USUARIO\Documents\vpncompartido

# Carpeta donde se guardan los logs diarios
LOGS_FOLDER=C:\VPN_MIFIBRA\Logs

# =============================================================================
# GOOGLE SHEETS
# =============================================================================

# Ruta completa al archivo JSON de la cuenta de servicio de Google Cloud
# Obtener desde: Google Cloud Console → IAM → Cuentas de servicio → Claves
GOOGLE_CREDENTIALS_FILE=C:\Credentials\nombre-del-archivo.json

# ID del Google Sheets de destino
# Se encuentra en la URL: docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=

# =============================================================================
# PROXY — excluir dominios de Google del proxy corporativo
# =============================================================================
NO_PROXY=googleapis.com,google.com,accounts.google.com
HTTPS_PROXY=
HTTP_PROXY=

# =============================================================================
# TIEMPOS Y REINTENTOS
# =============================================================================
NETWORK_CHECK_TIMEOUT=15
MAX_RETRIES=2
RETRY_DELAY=5
